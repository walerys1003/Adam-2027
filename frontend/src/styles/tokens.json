    "e1":     { "$value": "0 1px 2px rgba(14,26,46,0.04), 0 0 0 1px rgba(14,26,46,0.05)" },
    "e2":     { "$value": "0 2px 8px rgba(14,26,46,0.06), 0 0 0 1px rgba(14,26,46,0.05)" },
    "e3":     { "$value": "0 8px 24px rgba(14,26,46,0.08), 0 0 0 1px rgba(14,26,46,0.06)" },
    "e4":     { "$value": "0 20px 48px rgba(14,26,46,0.12), 0 0 0 1px rgba(14,26,46,0.08)" },
