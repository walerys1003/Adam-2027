# ============================================================
# ADAM · Frontend — konfiguracja środowiska (Vite)
# Skopiuj do `.env.local` i uzupełnij wartości.
# `.env.local` NIE jest commitowany (patrz .gitignore).
# ============================================================

# Bazowy URL backendu (FastAPI, ETAP 9).
# - Pozostaw PUSTE => frontend używa wbudowanego mocka (USE_MOCK=true).
# - Ustaw np. http://localhost:8787 (dev) lub https://api.adam.example (prod)
#   => frontend przełącza się na prawdziwe API przez adapter realApi.
VITE_API_URL=

# WP-1: jawny przełącznik trybu API (nadrzędny wobec autodetekcji URL):
#   VITE_API_MODE=mock  => zawsze mock (nawet gdy VITE_API_URL ustawione)
#   VITE_API_MODE=real  => zawsze realny backend (wymaga VITE_API_URL)
#   (pominięte)         => auto: real gdy VITE_API_URL ustawione, inaczej mock
VITE_API_MODE=

# Klucz API wysyłany w nagłówku `X-API-Key` (musi zgadzać się z ADAM_API_KEY
# po stronie backendu). Puste => tryb deweloperski bez uwierzytelniania.
VITE_API_KEY=
