# --- Stage 1: Builder (CUDA-enabled dependencies) ---
FROM nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04 AS builder

# Build args - keep parity with Dockerfile where possible
ARG INCLUDE_VOSK=true
ARG INCLUDE_SHERPA=true
ARG INCLUDE_FASTER_WHISPER=true
ARG INCLUDE_WHISPER_CPP=true
ARG INCLUDE_TONE=false
ARG INCLUDE_PIPER=true
ARG INCLUDE_KOKORO=true
ARG INCLUDE_MELOTTS=false
ARG INCLUDE_SILERO=false
ARG INCLUDE_LLAMA=true
ARG LLAMA_CUDA_ARCHITECTURES=""
ARG MELOTTS_GIT_REF=209145371cff8fc3bd60d7be902ea69cbdb7965a

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get -o Acquire::Retries=5 update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        python3-pip \
        build-essential \
        cmake \
        git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/app

# Create virtual environment
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
ENV NLTK_DATA="/opt/venv/nltk_data"
ENV CUDA_HOME=/usr/local/cuda
ENV LIBRARY_PATH="${CUDA_HOME}/lib64/stubs:${LIBRARY_PATH}"
ENV LD_LIBRARY_PATH="${CUDA_HOME}/lib64/stubs:${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}"

# Make libcuda SONAME discoverable during build-time linking in containers.
RUN if [ -f "${CUDA_HOME}/lib64/stubs/libcuda.so" ] && [ ! -e "${CUDA_HOME}/lib64/stubs/libcuda.so.1" ]; then \
        ln -s "${CUDA_HOME}/lib64/stubs/libcuda.so" "${CUDA_HOME}/lib64/stubs/libcuda.so.1"; \
    fi

# Copy requirements first for optimal caching and shared optional-backend pins
COPY requirements.txt .
COPY requirements-base.txt .

# Install base dependencies (always required)
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -r requirements-base.txt

# Conditionally install backends based on build args
RUN if [ "$INCLUDE_VOSK" = "true" ]; then \
        pip install --no-cache-dir vosk==0.3.45; \
    fi

RUN if [ "$INCLUDE_SHERPA" = "true" ]; then \
        SHERPA_REQUIREMENT="$(grep -m 1 '^sherpa-onnx==' requirements.txt || true)"; \
        if [ -z "$SHERPA_REQUIREMENT" ]; then \
            echo "❌ INCLUDE_SHERPA=true but requirements.txt has no sherpa-onnx entry" >&2; \
            exit 1; \
        fi; \
        pip install --no-cache-dir "$SHERPA_REQUIREMENT"; \
    fi

RUN if [ "$INCLUDE_FASTER_WHISPER" = "true" ]; then \
        FASTER_WHISPER_REQUIREMENT="$(grep -m 1 '^faster-whisper==' requirements.txt || true)"; \
        if [ -z "$FASTER_WHISPER_REQUIREMENT" ]; then echo "❌ Missing faster-whisper pin" >&2; exit 1; fi; \
        pip install --no-cache-dir "$FASTER_WHISPER_REQUIREMENT"; \
    fi

RUN if [ "$INCLUDE_WHISPER_CPP" = "true" ]; then \
        pip install --no-cache-dir pywhispercpp==1.2.0; \
    fi

RUN if [ "$INCLUDE_TONE" = "true" ]; then \
        pip install --no-cache-dir "git+https://github.com/voicekit-team/T-one.git@3c5b6c015038173840e62cea99e10cdb1c759116#egg=tone"; \
    fi

RUN if [ "$INCLUDE_PIPER" = "true" ]; then \
        pip install --no-cache-dir piper-tts==1.2.0; \
    fi

RUN if [ "$INCLUDE_KOKORO" = "true" ]; then \
        KOKORO_REQUIREMENT="$(grep -m 1 '^kokoro==' requirements.txt || true)"; \
        TORCH_REQUIREMENT="$(grep -m 1 '^torch==' requirements.txt || true)"; \
        TRANSFORMERS_REQUIREMENT="$(grep -m 1 '^transformers==' requirements.txt || true)"; \
        HF_HUB_REQUIREMENT="$(grep -m 1 '^huggingface-hub==' requirements.txt || true)"; \
        if [ -z "$KOKORO_REQUIREMENT" ]; then echo "❌ Missing kokoro pin" >&2; exit 1; fi; \
        if [ -z "$TORCH_REQUIREMENT" ]; then echo "❌ Missing torch pin" >&2; exit 1; fi; \
        if [ -z "$TRANSFORMERS_REQUIREMENT" ] || [ -z "$HF_HUB_REQUIREMENT" ]; then echo "❌ Missing transformers/huggingface-hub pins" >&2; exit 1; fi; \
        pip install --no-cache-dir "$TORCH_REQUIREMENT" && \
        pip install --no-cache-dir "$TRANSFORMERS_REQUIREMENT" "$HF_HUB_REQUIREMENT" && \
        pip install --no-cache-dir "$KOKORO_REQUIREMENT"; \
    fi

RUN if [ "$INCLUDE_MELOTTS" = "true" ]; then \
        pip install --no-cache-dir --upgrade pip setuptools wheel && \
        git clone https://github.com/myshell-ai/MeloTTS.git /tmp/MeloTTS && \
        cd /tmp/MeloTTS && \
        git checkout "${MELOTTS_GIT_REF}" && \
        python -c "from pathlib import Path; p=Path('/tmp/MeloTTS/setup.py'); s=p.read_text(); s=s.replace(\"from pip.req import parse_requirements\\n\", \"\"); s=s.replace(\"install_reqs = parse_requirements('requirements.txt')\\nreqs = [str(ir.req) for ir in install_reqs]\\n\", \"with open(os.path.join(cwd, 'requirements.txt'), encoding='utf-8') as _f:\\n    reqs = [ln.strip() for ln in _f if ln.strip() and not ln.startswith('#')]\\n\"); p.write_text(s); req=[]; ex=('torch','torchaudio','gradio'); [req.append(ln.strip()) for ln in Path('/tmp/MeloTTS/requirements.txt').read_text().splitlines() if ln.strip() and not ln.strip().startswith('#') and not ln.strip().lower().startswith(ex)]; Path('/tmp/MeloTTS/requirements.filtered.txt').write_text('\\n'.join(req)+'\\n'); print(f'MeloTTS filtered requirements prepared: {len(req)} packages')" && \
        pip install --no-cache-dir -r requirements.filtered.txt && \
        pip install --no-cache-dir "setuptools<81" && \
        TORCH_REQUIREMENT="$(grep -m 1 '^torch==' /usr/src/app/requirements.txt || true)" && \
        TORCHAUDIO_REQUIREMENT="$(grep -m 1 '^torchaudio==' /usr/src/app/requirements.txt || true)" && \
        if [ -z "$TORCH_REQUIREMENT" ] || [ -z "$TORCHAUDIO_REQUIREMENT" ]; then echo "❌ Missing torch/torchaudio pins" >&2; exit 1; fi && \
        if ! python -c "import importlib.util,sys; sys.exit(0 if importlib.util.find_spec('torch') else 1)"; then pip install --no-cache-dir "$TORCH_REQUIREMENT"; fi && \
        if ! python -c "import importlib.util,sys; sys.exit(0 if importlib.util.find_spec('torchaudio') else 1)"; then pip install --no-cache-dir "$TORCHAUDIO_REQUIREMENT"; fi && \
        pip install --no-cache-dir --no-build-isolation --no-deps . && \
        cd / && rm -rf /tmp/MeloTTS && \
        python -m unidic download || true && \
        python -c "import nltk; nltk.download('averaged_perceptron_tagger_eng', download_dir='/opt/venv/nltk_data')" || true && \
        python -c "from transformers import AutoTokenizer; AutoTokenizer.from_pretrained('bert-base-uncased')" || true && \
        python -c "from melo.api import TTS; print('MeloTTS package ready')"; \
    fi

# Ensure cache dir exists so COPY --from=builder never fails
RUN mkdir -p /opt/silero-cache

RUN if [ "$INCLUDE_SILERO" = "true" ]; then \
        echo "📦 Installing Silero TTS dependencies..." && \
        TORCH_REQUIREMENT="$(grep -m 1 '^torch==' requirements.txt || true)"; \
        if [ -z "$TORCH_REQUIREMENT" ]; then echo "❌ Missing torch pin" >&2; exit 1; fi; \
        if ! python3 -c "import importlib.util,sys; sys.exit(0 if importlib.util.find_spec('torch') else 1)"; then \
            pip install --no-cache-dir "$TORCH_REQUIREMENT"; \
        fi && \
        pip install --no-cache-dir omegaconf && \
        echo "📦 Pre-caching Silero Russian model (best effort)..." && \
        python3 -c "import torch; torch.hub.set_dir('/opt/silero-cache'); torch.hub.load('snakers4/silero-models:v5.5', 'silero_tts', language='ru', speaker='v3_1_ru', trust_repo=True)" || true && \
        echo "✅ Silero TTS ready"; \
    fi

RUN if [ "$INCLUDE_LLAMA" = "true" ]; then \
        LLAMA_CPP_REQUIREMENT="$(grep -m 1 '^llama-cpp-python==' requirements.txt || true)"; \
        if [ -z "$LLAMA_CPP_REQUIREMENT" ]; then \
            echo "❌ INCLUDE_LLAMA=true but requirements.txt has no llama-cpp-python entry" >&2; \
            exit 1; \
        fi; \
        CUDA_ARCH_ARG=""; \
        if [ -n "$LLAMA_CUDA_ARCHITECTURES" ]; then \
            CUDA_ARCH_ARG="-DCMAKE_CUDA_ARCHITECTURES=$LLAMA_CUDA_ARCHITECTURES"; \
            echo "Building llama.cpp for CUDA architecture(s): $LLAMA_CUDA_ARCHITECTURES"; \
        fi; \
        CMAKE_ARGS="-DGGML_CUDA=on -DLLAMA_BUILD_TESTS=OFF -DLLAMA_BUILD_EXAMPLES=OFF -DLLAMA_BUILD_TOOLS=OFF $CUDA_ARCH_ARG" \
        FORCE_CMAKE=1 \
        pip install --no-cache-dir "$LLAMA_CPP_REQUIREMENT"; \
    fi

# MeloTTS declares Gradio for its standalone web demo; AVA does not ship that UI.
# Fail for every other broken or incompatible dependency.
RUN CHECK_OUTPUT="$(pip check 2>&1 || true)"; \
    UNEXPECTED="$(printf '%s\n' "$CHECK_OUTPUT" | \
        grep -v -e '^No broken requirements found\.$' \
                -e '^melotts .* requires gradio, which is not installed\.$' || true)"; \
    if [ -n "$UNEXPECTED" ]; then printf '%s\n' "$UNEXPECTED" >&2; exit 1; fi; \
    echo "No unexpected broken requirements found."

# Pre-install spacy model for Kokoro TTS (only if Kokoro included)
RUN if [ "$INCLUDE_KOKORO" = "true" ]; then \
        python -m spacy download en_core_web_sm; \
    fi

# --- Stage 2: Final Runtime Image (CUDA runtime) ---
FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

# Build argument to optionally include Kroko embedded server
ARG INCLUDE_KROKO_EMBEDDED=false

ENV DEBIAN_FRONTEND=noninteractive

# Install runtime dependencies
RUN apt-get -o Acquire::Retries=5 update && apt-get install -y --no-install-recommends \
    python3 \
    python3-venv \
    tzdata \
    libsndfile1 \
    libasound2 \
    libportaudio2 \
    libgomp1 \
    libatomic1 \
    sox \
    wget \
    espeak-ng \
    && rm -rf /var/lib/apt/lists/*

# Optional: Install Kroko ONNX server for embedded mode
ARG ONNX_RUNTIME_SHA256="89b153af88746665909c758a06797175ae366280cbf25502c41eb5955f9a555e"
ARG KROKO_SERVER_SHA256=""

RUN if [ "$INCLUDE_KROKO_EMBEDDED" = "true" ]; then \
        wget -q https://github.com/microsoft/onnxruntime/releases/download/v1.17.1/onnxruntime-linux-x64-1.17.1.tgz \
            -O /tmp/onnxruntime.tgz && \
        ACTUAL_ONNX_SHA=$(sha256sum /tmp/onnxruntime.tgz | cut -d' ' -f1) && \
        if [ -n "$ONNX_RUNTIME_SHA256" ] && [ "$ACTUAL_ONNX_SHA" != "$ONNX_RUNTIME_SHA256" ]; then \
            echo "ONNX Runtime checksum mismatch. Build aborted." && \
            exit 1; \
        fi && \
        tar -xzf /tmp/onnxruntime.tgz -C /tmp && \
        mv /tmp/onnxruntime-linux-x64-1.17.1/lib/* /usr/lib/ && \
        rm -rf /tmp/onnxruntime* && \
        wget -q https://download.kroko.ai/binaries/kroko-onnx-online-websocket-server \
            -O /usr/local/bin/kroko-server && \
        ACTUAL_KROKO_SHA=$(sha256sum /usr/local/bin/kroko-server | cut -d' ' -f1) && \
        if [ -n "$KROKO_SERVER_SHA256" ] && [ "$ACTUAL_KROKO_SHA" != "$KROKO_SERVER_SHA256" ]; then \
            echo "Kroko checksum mismatch. Build aborted." && \
            exit 1; \
        fi && \
        if [ -z "$KROKO_SERVER_SHA256" ]; then \
            echo "⚠️  WARNING: KROKO_SERVER_SHA256 not set. For production, set --build-arg KROKO_SERVER_SHA256=${ACTUAL_KROKO_SHA}"; \
        fi && \
        chmod +x /usr/local/bin/kroko-server; \
    fi

WORKDIR /app

# Create non-root user for security
RUN useradd --create-home appuser
USER appuser

# Copy the virtual environment from builder
COPY --from=builder /opt/venv /opt/venv
COPY --from=builder --chown=appuser:appuser /opt/silero-cache /app/models/tts/silero

# Copy application source code
COPY --chown=appuser:appuser . .

# Set PATH for virtual environment
ENV PATH="/opt/venv/bin:$PATH"
ENV NLTK_DATA="/opt/venv/nltk_data"

# Document the WebSocket server port (informational; host networking ignores EXPOSE)
EXPOSE 8765

# Run the application
CMD ["python", "main.py"]
